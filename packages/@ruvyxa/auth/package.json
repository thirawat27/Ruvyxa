{
  "name": "@ruvyxa/auth",
  "version": "1.0.17",
  "description": "Secure sessions and provider-driven authentication for Ruvyxa applications.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "keywords": ["ruvyxa", "auth", "oauth", "magic-link", "webauthn", "session"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thirawat27/ruvyxa.git",
    "directory": "packages/@ruvyxa/auth"
  },
  "bugs": { "url": "https://github.com/thirawat27/ruvyxa/issues" },
  "homepage": "https://github.com/thirawat27/ruvyxa#readme",
  "engines": { "node": ">=22.0.0" },
  "publishConfig": { "access": "public" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./client": { "types": "./dist/client.d.ts", "default": "./dist/client.js" }
  },
  "dependencies": { "@ruvyxa/core": "workspace:^" },
  "devDependencies": { "@types/node": "^26.1.1" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.check.json",
    "test": "pnpm run build && node --test \"../../../tests/packages/auth/**/*.test.ts\"",
    "format": "tsc -p tsconfig.check.json",
    "prepack": "pnpm run build"
  }
}
