{
  "name": "@ruvyxa/realtime",
  "version": "1.0.18",
  "description": "Native action-driven WebSocket realtime transport for self-hosted Ruvyxa applications.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "keywords": ["ruvyxa", "realtime", "websocket", "server-actions", "subscriptions"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thirawat27/ruvyxa.git",
    "directory": "packages/@ruvyxa/realtime"
  },
  "bugs": {
    "url": "https://github.com/thirawat27/ruvyxa/issues"
  },
  "homepage": "https://github.com/thirawat27/ruvyxa#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "dependencies": {
    "@ruvyxa/core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.check.json",
    "test": "pnpm run build && node --test \"../../../tests/packages/realtime/**/*.test.ts\"",
    "format": "tsc -p tsconfig.check.json",
    "prepack": "pnpm run build"
  }
}
