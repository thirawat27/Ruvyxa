{
  "name": "ruvyxa",
  "version": "1.0.14",
  "description": "The Ruvyxa CLI and runtime for building, validating, serving, and shipping production-minded web applications.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ruvyxa": "./bin/ruvyxa.js"
  },
  "files": [
    "bin",
    "dist",
    "native-bin",
    "runtime/action-renderer.mjs",
    "runtime/api-renderer.mjs",
    "runtime/client-renderer.mjs",
    "runtime/ruvyxa-compiler.mjs",
    "runtime/config-renderer.mjs",
    "runtime/plugin-runner.mjs",
    "runtime/ssg-renderer.mjs",
    "runtime/ssr-renderer.mjs",
    "runtime/worker-pool.mjs",
    "scripts/native-platform.mjs",
    "README.md"
  ],
  "keywords": [
    "framework",
    "typescript",
    "react",
    "rust",
    "ssr",
    "fullstack",
    "middleware",
    "wasm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thirawat27/ruvyxa.git",
    "directory": "packages/ruvyxa"
  },
  "bugs": {
    "url": "https://github.com/thirawat27/ruvyxa/issues"
  },
  "homepage": "https://github.com/thirawat27/ruvyxa#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@ruvyxa/core": "workspace:^"
  },
  "optionalDependencies": {
    "@ruvyxa/cli-darwin-arm64": "workspace:^",
    "@ruvyxa/cli-linux-arm64": "workspace:^",
    "@ruvyxa/cli-linux-x64": "workspace:^",
    "@ruvyxa/cli-win32-arm64": "workspace:^",
    "@ruvyxa/cli-win32-x64": "workspace:^"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.check.json",
    "test": "node --test \"../../tests/packages/ruvyxa/**/*.test.mjs\"",
    "format": "tsc -p tsconfig.check.json",
    "prepack": "pnpm run build && node scripts/prepare-native-binary.mjs"
  }
}
