{
  "name": "demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cargo run -p ruvyxa_cli -- dev --root .",
    "build": "cargo run -p ruvyxa_cli -- build --root .",
    "start": "cargo run -p ruvyxa_cli -- start --root .",
    "routes": "cargo run -p ruvyxa_cli -- routes --root .",
    "analyze": "cargo run -p ruvyxa_cli -- analyze --root .",
    "check": "cargo run -p ruvyxa_cli -- check --root .",
    "preview": "cargo run -p ruvyxa_cli -- start --root . --port 3000",
    "parity": "cargo run -p ruvyxa_cli -- test:parity --root .",
    "doctor": "cargo run -p ruvyxa_cli -- doctor --root .",
    "clean": "cargo run -p ruvyxa_cli -- clean --root .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ruvyxa/realtime": "workspace:*",
    "@ruvyxa/react": "workspace:*",
    "ruvyxa": "workspace:*",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@ruvyxa/adapter-node": "workspace:^",
    "@ruvyxa/adapter-bun": "workspace:^",
    "@ruvyxa/adapter-static": "workspace:^",
    "@ruvyxa/adapter-vercel": "workspace:^",
    "@ruvyxa/adapter-netlify": "workspace:^",
    "@ruvyxa/adapter-cloudflare": "workspace:^"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
